# App
NEXT_PUBLIC_APP_NAME=EKALOX
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Required for lib/supabase clients)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Storage
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=ekalox-uploads

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/ekalox

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_secure_random_string

# Admin OTP
ADMIN_OTP_EMAIL=secure-admin-email@example.com
ADMIN_OTP_FROM_EMAIL=no-reply@example.com
ADMIN_OTP_SECRET=replace_with_a_long_random_secret
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
ADMIN_OTP_TTL_MINUTES=5
ADMIN_OTP_RESEND_COOLDOWN_SECONDS=60
ADMIN_OTP_MAX_ATTEMPTS=5

# Razorpay test mode
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret
